APP_NAME=OCR API
APP_ENV=dev
DEBUG=false
API_V1_PREFIX=/api/v1
OCR_SCAN_MAX_FILE_SIZE=10485760
OCR_SCAN_MAX_CONCURRENCY=1
OCR_SCAN_QUEUE_TIMEOUT_SECONDS=30
OCR_SCAN_WARMUP_ON_STARTUP=false
DEEPSEEK_MODEL_PATH=/data/ai/models/DeepSeek-OCR-2
DEEPSEEK_PROMPT=<image>\n<|grounding|>Convert the document to markdown. 
DEEPSEEK_BASE_SIZE=1024
DEEPSEEK_IMAGE_SIZE=1024
DEEPSEEK_CROP_MODE=false
DEEPSEEK_TEST_COMPRESS=false
DEEPSEEK_DEVICE=cuda
DEEPSEEK_USE_BFLOAT16=true

# 应用基础配置
# 服务名称，会在根路由和健康检查响应中展示。
APP_NAME=OCR API
# 运行环境标识（例如：dev/staging/prod）。
APP_ENV=dev
# 是否开启调试模式（生产环境建议关闭）。
DEBUG=false
# v1 接口统一前缀。
API_V1_PREFIX=/api/v1

# OCR 请求保护参数
# 上传文件大小上限（字节），默认 10 MB。
OCR_SCAN_MAX_FILE_SIZE=10485760
# 单实例部署时，每个进程允许的 scan 并发数。
OCR_SCAN_MAX_CONCURRENCY=1
# 多卡多实例部署时，GPU0 对应实例的 scan 并发数。
OCR_SCAN_MAX_CONCURRENCY_GPU0=1
# 多卡多实例部署时，GPU1 对应实例的 scan 并发数。
OCR_SCAN_MAX_CONCURRENCY_GPU1=1
# 请求在队列中等待的最大秒数，超时返回 HTTP 429。
OCR_SCAN_QUEUE_TIMEOUT_SECONDS=30
# 启动时预热 OCR 模型，用于降低首个请求延迟。
OCR_SCAN_WARMUP_ON_STARTUP=true

# DeepSeek OCR 运行时参数
# 本地模型目录（需挂载到容器/服务内）。
DEEPSEEK_MODEL_PATH=/data/ai/models/DeepSeek-OCR-2
# 传给 model.infer() 的推理提示词。
DEEPSEEK_PROMPT=<image>\n<|grounding|>Convert the document to markdown. 
# DeepSeek 图像预处理 base_size。
DEEPSEEK_BASE_SIZE=1024
# DeepSeek 图像预处理 image_size。
DEEPSEEK_IMAGE_SIZE=1024
# 裁剪模式开关（仅支持 true/false）。
DEEPSEEK_CROP_MODE=false
# 是否启用 DeepSeek 测试压缩路径（生产通常为 false）。
DEEPSEEK_TEST_COMPRESS=false
# 推理设备：cuda 或 cpu。
DEEPSEEK_DEVICE=cuda
# CUDA 下是否使用 bfloat16，以降低显存占用并提升吞吐。
DEEPSEEK_USE_BFLOAT16=true
